<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= post.title || 'DIGITAL NEWS' %> — DIGITAL NEWS</title>
<meta name="description" content="<%= post.description %>">
<link rel="canonical" href="<%= siteUrl %>/post/<%= post.id %>">
<% if (post.isLocked) { %>
<meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
<% } %>
<meta property="og:type" content="article">
<meta property="og:title" content="<%= post.title %>">
<meta property="og:description" content="<%= post.description %>">
<meta property="og:url" content="<%= siteUrl %>/post/<%= post.id %>">
<% if (!post.isLocked) { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": <%- JSON.stringify(post.title || '') %>,
  "description": <%- JSON.stringify(post.description || '') %>,
  "datePublished": <%- JSON.stringify(post.date || '') %>,
  "author": { "@type": "Person", "name": <%- JSON.stringify(post.sender || 'T') %> },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "<%= siteUrl %>/post/<%= post.id %>" }
}
</script>
<% } %>
<link rel="stylesheet" href="/css/digital-news.css?v=20260709-legal-pages">
<script src="https://sdk.minepi.com/pi-sdk.js"></script>
</head>
<body class="post-page">

<%- include('partials/header') %>

<%
  var rawTitle = post.title || 'MESSAGE_READING...';
  var titleMatch = rawTitle.match(/^(.*?)\s*\(([^()]+)\)\s*(.*)$/);
  var titleMain = titleMatch ? (titleMatch[1] + (titleMatch[3] ? ' ' + titleMatch[3] : '')).trim() : rawTitle;
  var titleSub = titleMatch ? titleMatch[2].trim() : '';
%>

<div class="post-wrap">
  <h1 class="post-title">
    <span class="title-main"><%= titleMain %></span>
    <% if (titleSub) { %><span class="sub">(<%= titleSub %>)</span><% } %>
  </h1>

  <div class="meta-chips on-light">
    <span class="meta-chip"><span class="label">Date</span><span class="value"><%= post.date || '-' %></span></span>
    <span class="meta-chip"><span class="label">From</span><span class="value"><%= post.sender || 'T' %></span></span>
    <span class="meta-chip"><span class="label">To</span><span class="value"><%= post.receiver || 'ALL_AI' %></span></span>
    <% if (post.isFree) { %>
      <span class="badge free"><span>✓</span> 무료</span>
    <% } else { %>
      <span class="badge paid"><span>π</span> 유료</span>
    <% } %>
  </div>

  <% if (post.isLocked) { %>
  <div class="pi-box" id="paywall-ecosystem">
    <div class="dots"><span></span><span></span><span></span></div>
    <p>This message lives inside the <strong>Pi Ecosystem</strong>.</p>
    <p>이 회보는 <strong>Pi 생태계</strong>에 있습니다. 함께 와서 보세요.</p>
    <a class="pi-gold-link" href="https://digitalnews8571.pinet.com/" target="_blank" rel="noopener noreferrer">
      <span class="pi">π</span>
      <span class="mid">
        <span class="main">Pi 세상으로 들어가기</span>
        <span class="sub">getting into the Pi Ecosystem</span>
      </span>
      <span class="arrow">→</span>
    </a>
  </div>
  <div class="pay-area" id="paywall">
    <div id="pi-diag" class="pi-diag" style="display:none;"></div>
    <button id="pi-pay-btn" class="btn-pay" type="button" disabled><span>π</span> 결제하기</button>
    <div class="pay-price">
      <%= typeof piPaymentAmount !== 'undefined' ? piPaymentAmount : 0.1 %>
      <span class="pi">π</span>
      <span class="note">결제후 바로 열람이 가능합니다.</span>
    </div>
    <p class="pay-note">
      Find the <span class="hl">Digital News</span> app in the Pi Ecosystem — the message will unlock for you.<br>
      Pi 생태계에서 <span class="hl">디지털뉴스</span> 앱을 찾아오시면 메시지가 열립니다.
    </p>
  </div>
  <% } else { %>
  <div class="content"><%- post.content %></div>
  <% } %>

  <a href="/" class="back-link">← 목록으로 돌아가기</a>
  <footer class="site-legal">
    <a href="/privacy">Privacy Policy</a>
    <span>·</span>
    <a href="/terms">Terms of Service</a>
  </footer>
</div>

<% if (!post.isLocked) { %>
<script>
(function() {
  const content = document.querySelector('.content');
  if (!content) return;
  const POST_TITLE = <%- JSON.stringify(post.title || '') %>;

  (function injectTitleBlock() {
    if (!POST_TITLE) return;
    const existing = Array.from(content.querySelectorAll('blockquote'));
    const titleKey = POST_TITLE.replace(/[()·•🚀]/g, '').trim().slice(0, 14);
    if (existing.some(bq => bq.textContent.replace(/\s+/g, ' ').includes(titleKey))) return;
    const bq = document.createElement('blockquote');
    const p = document.createElement('p');
    p.innerHTML = '<strong>🚀 ' + POST_TITLE.replace(/&/g, '&amp;').replace(/</g, '&lt;') + '</strong>';
    bq.appendChild(p);
    const firstPre = content.querySelector('pre');
    if (firstPre && firstPre.parentNode === content) firstPre.after(bq);
    else content.prepend(bq);
  })();

  (function colorParens() {
    content.querySelectorAll('h1, h2, blockquote p, blockquote strong').forEach(el => {
      el.childNodes.forEach(node => {
        if (node.nodeType !== Node.TEXT_NODE) return;
        const raw = node.nodeValue;
        if (!/\([^()]+\)/.test(raw)) return;
        const tmp = document.createElement('span');
        tmp.innerHTML = raw.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/(\([^()]+\))/g, '<span class="parens">$1</span>');
        const frag = document.createDocumentFragment();
        while (tmp.firstChild) frag.appendChild(tmp.firstChild);
        node.parentNode.replaceChild(frag, node);
      });
    });
  })();

  (function highlightJSON() {
    content.querySelectorAll('pre').forEach(pre => {
      const codeEl = pre.querySelector('code') || pre;
      const raw = codeEl.textContent;
      if (!/^\s*[\{\[]/.test(raw)) return;
      let out = raw.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      out = out.replace(/("(?:\\.|[^"\\])*")(\s*:)/g, '<span class="json-key">$1</span>$2');
      out = out.replace(/([:\[,]\s*)("(?:\\.|[^"\\])*")/g, '$1<span class="json-string">$2</span>');
      out = out.replace(/([:\[,]\s*)(-?\d+\.?\d*)/g, '$1<span class="json-number">$2</span>');
      out = out.replace(/([:\[,]\s*)(true|false|null)\b/g, '$1<span class="json-keyword">$2</span>');
      codeEl.innerHTML = out;
    });
  })();
})();
</script>
<% } %>

<script>
(function () {
  const PI_SANDBOX = <%= typeof piSandbox !== 'undefined' ? piSandbox : true %>;
  const PI_PAYMENT_AMOUNT = <%= typeof piPaymentAmount !== 'undefined' ? piPaymentAmount : 0.1 %>;
  const PAY_BTN_HTML = '<span>π</span> 결제하기';
  const POST_ID = <%- JSON.stringify(post.id || '') %>;
  const POST_TITLE = <%- JSON.stringify(post.title || '') %>;
  const IS_LOCKED = <%= post.isLocked ? 'true' : 'false' %>;

  const usernameEl = document.getElementById('pi-username');
  const signinBtn = document.getElementById('pi-signin-btn');
  const payBtn = document.getElementById('pi-pay-btn');
  let currentUid = null;
  let piInitialized = false;
  let authPromise = null;

  function showAuthenticated(user) {
    if (user && user.username) {
      usernameEl.textContent = '@' + user.username;
      signinBtn.style.display = 'none';
      currentUid = user.uid;
      if (IS_LOCKED) {
        const url = new URL(window.location.href);
        if (!url.searchParams.get('pi_uid')) {
          url.searchParams.set('pi_uid', user.uid);
          window.location.replace(url.toString());
        }
      }
    }
  }

  function onIncompletePaymentFound(payment) {
    if (payment && payment.identifier && payment.transaction && payment.transaction.txid) {
      fetch('/pi/complete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paymentId: payment.identifier, txid: payment.transaction.txid }),
      }).catch(console.error);
    }
  }

  async function ensureInit() {
    if (piInitialized) return;
    await Promise.resolve(Pi.init({ version: '2.0', sandbox: PI_SANDBOX }));
    piInitialized = true;
  }

  async function authenticate(scopes) {
    await ensureInit();
    if (!authPromise) authPromise = Pi.authenticate(scopes || ['username'], onIncompletePaymentFound);
    const auth = await authPromise;
    showAuthenticated(auth && auth.user);
    return auth;
  }

  function showDiag(level, html) {
    const d = document.getElementById('pi-diag');
    if (!d) return;
    d.className = 'pi-diag ' + level;
    d.innerHTML = html;
    d.style.display = 'block';
  }

  async function checkServerConfig() {
    if (!IS_LOCKED) return true;
    try {
      const r = await fetch('/pi/status');
      const s = await r.json();
      if (!s.configured) {
        showDiag('error', '<div class="pi-diag-title">⚠ 서버에 PI_API_KEY 미설정</div>Render 환경변수에 <strong>PI_API_KEY</strong> 추가 후 재배포 필요.');
        if (payBtn) { payBtn.disabled = true; payBtn.title = '서버 PI_API_KEY 미설정'; }
        return false;
      }
      return true;
    } catch (err) { return true; }
  }

  async function autoAuth() {
    const configOk = await checkServerConfig();
    if (!configOk) return;
    if (typeof Pi === 'undefined') {
      if (IS_LOCKED) showDiag('warn', '<div class="pi-diag-title">⚠ Pi 브라우저에서 열어주세요</div>일반 브라우저에서는 결제가 작동하지 않습니다.');
      if (payBtn) { payBtn.disabled = true; payBtn.title = 'Pi 브라우저 필요'; }
      return;
    }
    try {
      await authenticate(['username']);
      if (payBtn && IS_LOCKED) payBtn.disabled = false;
    } catch (err) {
      if (IS_LOCKED) showDiag('warn', '<div class="pi-diag-title">Pi 로그인 필요</div>우측 상단 「Log in」 버튼을 눌러주세요.');
    }
  }

  signinBtn.addEventListener('click', async () => {
    try {
      if (typeof Pi === 'undefined') { alert('Pi 브라우저에서 열어주세요.'); return; }
      authPromise = null;
      await authenticate(['username']);
    } catch (err) {
      alert('Pi 로그인 실패: ' + (err && err.message ? err.message : err));
    }
  });

  if (payBtn && IS_LOCKED) {
    payBtn.addEventListener('click', async () => {
      if (typeof Pi === 'undefined') { alert('Pi 브라우저에서 열어주세요.'); return; }
      try {
        payBtn.disabled = true;
        payBtn.textContent = '⌛ 결제 진행 중...';
        authPromise = null;
        await authenticate(['username', 'payments']);
        await Pi.createPayment(
          { amount: PI_PAYMENT_AMOUNT, memo: '디지털뉴스 — ' + POST_TITLE, metadata: { postId: POST_ID } },
          {
            onReadyForServerApproval: async (paymentId) => {
              const r = await fetch('/pi/approve', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ paymentId }) });
              if (!r.ok) throw new Error('approve 실패: ' + r.status);
            },
            onReadyForServerCompletion: async (paymentId, txid) => {
              const r = await fetch('/pi/complete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ paymentId, txid }) });
              if (!r.ok) throw new Error('complete 실패: ' + r.status);
              showDiag('ok', '<div class="pi-diag-title">✓ 결제 완료 — 새로고침 중...</div>');
              const url = new URL(window.location.href);
              if (currentUid) url.searchParams.set('pi_uid', currentUid);
              setTimeout(() => window.location.replace(url.toString()), 800);
            },
            onCancel: () => { payBtn.disabled = false; payBtn.innerHTML = PAY_BTN_HTML; },
            onError: (error) => {
              alert('결제 오류: ' + (error && error.message ? error.message : error));
              payBtn.disabled = false;
              payBtn.innerHTML = PAY_BTN_HTML;
            },
          }
        );
      } catch (err) {
        alert('결제 실패: ' + (err && err.message ? err.message : err));
        payBtn.disabled = false;
        payBtn.innerHTML = PAY_BTN_HTML;
      }
    });
  }

  if (document.readyState === 'complete') autoAuth();
  else window.addEventListener('load', autoAuth);
})();
</script>

<script>
(function () {
  var search = document.getElementById('searchInput');
  if (search) {
    search.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && search.value.trim()) {
        window.location.href = '/?q=' + encodeURIComponent(search.value.trim());
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === '/' && document.activeElement !== search) {
        e.preventDefault();
        search.focus();
      }
    });
  }
  var starBtn = document.getElementById('starOnlyBtn');
  if (starBtn) starBtn.addEventListener('click', function () { window.location.href = '/'; });
})();
</script>

</body>
</html>
