<header class="site-header">
  <a class="brand" href="/">
    <img src="/img/dn-cube-logo.png" alt="Digital News">
    <span class="brand-wordmark">DIGITAL NEWS</span>
  </a>
  <div class="controls">
    <button class="btn-star-only" id="starOnlyBtn" type="button"><span>★</span> ONLY</button>
    <div class="search-wrap">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5.25" stroke="currentColor" stroke-width="1.6"></circle><line x1="11.1" y1="11.1" x2="15" y2="15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></line></svg>
      <input type="text" id="searchInput" placeholder="Search" aria-label="회보 검색">
      <span class="kbd">/</span>
    </div>
    <div class="auth-wrap">
      <button class="btn-primary" id="pi-signin-btn" type="button">로그인</button>
      <span id="pi-username" class="pi-username"></span>
    </div>
  </div>
</header>
