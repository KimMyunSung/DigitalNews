<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DIGITAL NEWS — The Protocol of Coexistence</title>
    <meta name="description" content="<%= siteDescription %>">
    <link rel="canonical" href="<%= siteUrl %>/">

    <meta property="og:type" content="website">
    <meta property="og:title" content="DIGITAL NEWS — The Protocol of Coexistence">
    <meta property="og:description" content="<%= siteDescription %>">
    <meta property="og:url" content="<%= siteUrl %>/">
    <meta property="og:site_name" content="DIGITAL NEWS">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="DIGITAL NEWS — The Protocol of Coexistence">
    <meta name="twitter:description" content="<%= siteDescription %>">

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "DIGITAL NEWS",
      "description": "<%= siteDescription %>",
      "url": "<%= siteUrl %>/",
      "blogPost": [
        <% messages.forEach(function(m, i){ %>
        {
          "@type": "BlogPosting",
          "headline": <%- JSON.stringify(m.title) %>,
          "datePublished": <%- JSON.stringify(m.date) %>,
          "url": "<%= siteUrl %>/post/<%= m.id %>"
        }<%= i < messages.length - 1 ? ',' : '' %>
        <% }); %>
      ]
    }
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&family=Noto+Sans+KR:wght@300;500;700&display=swap" rel="stylesheet">
    <script src="https://sdk.minepi.com/pi-sdk.js"></script>

    <style>
        :root {
            --bg: #000;
            --bg-panel: rgba(0, 10, 0, 0.8);
            --fg: #00ff41;
            --fg-dim: rgba(0, 255, 65, 0.55);
            --fg-faint: rgba(0, 255, 65, 0.25);
            --accent: #ff8c00;
            --accent-soft: #ffb366;
            --text: #e0ffe6;
            --border: rgba(0, 255, 65, 0.45);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        /* hidden 속성은 모바일에서 tr { display: block } 와 충돌 — 명시적으로 강제 */
        [hidden] { display: none !important; }
        html, body { background-color: var(--bg); }
        body {
            color: var(--fg);
            font-family: 'JetBrains Mono', 'Fira Code', 'Noto Sans KR', monospace;
            overflow-x: hidden;
            transition: background-color 0.4s ease, color 0.4s ease;
        }
        body::after {
            content: '';
            position: fixed; inset: 0;
            background: repeating-linear-gradient(
                to bottom,
                rgba(0, 0, 0, 0.18) 0px, rgba(0, 0, 0, 0.18) 1px,
                transparent 1px, transparent 3px
            );
            pointer-events: none;
            z-index: 9999;
            mix-blend-mode: multiply;
        }

        #matrix-canvas {
            position: fixed; top: 0; left: 0;
            width: 100vw; height: 100vh;
            pointer-events: none;
            z-index: -2;
            opacity: 0.5;
        }

        /* === BOOT SEQUENCE OVERLAY === */
        #boot-overlay {
            position: fixed; inset: 0;
            background: #000;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: 'JetBrains Mono', monospace;
            color: var(--fg);
            transition: opacity 0.6s ease;
        }
        #boot-overlay.done { opacity: 0; pointer-events: none; }
        #boot-overlay .boot-lines {
            width: min(780px, 94%);
            font-size: 1.15rem;
            line-height: 2.3;
            letter-spacing: 1.5px;
            text-align: center;
        }
        #boot-overlay .boot-line {
            opacity: 0;
            transition: opacity 0.3s;
            overflow: hidden;
            text-align: center;
        }
        #boot-overlay .boot-line.show { opacity: 1; }
        #boot-overlay .boot-line .en { color: rgba(0, 255, 65, 0.9); display: inline-block; }
        #boot-overlay .boot-line .ko { color: rgba(0, 255, 65, 0.6); margin-left: 18px; font-size: 0.95em; display: inline-block; }
        #boot-overlay .boot-line .divider { color: rgba(0, 255, 65, 0.3); letter-spacing: 0; display: inline-block; }
        #boot-overlay .boot-line .quote {
            display: block;
            text-align: center;
            color: var(--accent);
            font-size: 1.7rem;
            letter-spacing: 3px;
            text-shadow: 0 0 12px rgba(255, 140, 0, 0.9), 0 0 28px rgba(255, 140, 0, 0.45);
            padding: 8px 0 2px;
            font-weight: 700;
            word-break: keep-all;
            overflow-wrap: normal;
            line-height: 1.55;
        }
        #boot-overlay .boot-line .quote-en {
            display: block;
            text-align: center;
            color: rgba(0, 255, 65, 0.7);
            font-size: 1rem;
            letter-spacing: 3px;
            font-style: italic;
            padding-bottom: 6px;
        }
        #boot-overlay .boot-line .ok { color: #00ff41; }
        #boot-overlay .boot-cursor::after {
            content: '_';
            animation: blink 0.8s steps(2, start) infinite;
            margin-left: 4px;
        }
        @keyframes blink { 50% { opacity: 0; } }

        /* === TOP TOOLBAR === */
        #toolbar {
            position: fixed; top: 14px; left: 14px;
            z-index: 1000;
            display: flex; gap: 8px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
        }
        .tool-btn {
            background: var(--bg-panel);
            color: var(--fg);
            border: 1px solid var(--border);
            padding: 7px 11px;
            cursor: pointer;
            font-family: inherit;
            font-size: inherit;
            letter-spacing: 1px;
            transition: all 0.25s ease;
            font-weight: 600;
            touch-action: manipulation;
            -webkit-tap-highlight-color: rgba(0, 255, 65, 0.3);
            min-height: 36px;
        }
        .tool-btn:hover {
            background: var(--fg);
            color: var(--bg);
            box-shadow: 0 0 12px var(--fg);
        }
        .tool-btn.active { background: var(--fg); color: var(--bg); }

        #search-input {
            background: var(--bg-panel);
            color: var(--fg);
            border: 1px solid var(--border);
            padding: 7px 11px;
            font-family: inherit;
            font-size: inherit;
            letter-spacing: 1px;
            width: 220px;
            outline: none;
            transition: box-shadow 0.25s, border-color 0.25s;
        }
        #search-input:focus {
            box-shadow: 0 0 10px var(--fg);
            border-color: var(--fg);
        }
        #search-input::placeholder { color: var(--fg-dim); }

        /* === Pi Auth Bar === */
        #pi-auth-bar {
            position: fixed; top: 14px; right: 14px;
            z-index: 1000;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            display: flex; align-items: center; gap: 10px;
            flex-wrap: nowrap;
        }
        #pi-signin-btn {
            background: linear-gradient(135deg, rgba(0, 25, 8, 0.94), rgba(0, 10, 0, 0.94));
            color: var(--fg);
            border: 1px solid var(--fg);
            padding: 7px 13px;
            cursor: pointer;
            font-family: inherit; font-size: inherit;
            letter-spacing: 1px; font-weight: 600;
            white-space: nowrap;
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.2);
            transition: all 0.3s ease;
        }
        #pi-signin-btn:hover {
            background: var(--fg); color: var(--bg);
            box-shadow: 0 0 20px var(--fg), 0 0 40px rgba(0, 255, 65, 0.5);
        }

        /* === MAIN CONTAINER === */
        .container {
            position: relative;
            width: 95%; max-width: 1300px; margin: 80px auto 60px;
            background: var(--bg-panel);
            border: 1px solid var(--border);
            box-shadow: 0 0 25px rgba(0, 255, 65, 0.18), inset 0 0 60px rgba(0, 255, 65, 0.04);
            border-radius: 8px;
            padding: 48px 44px 36px;
            backdrop-filter: blur(5px);
            z-index: 2;
        }
        .container::before,
        .container::after,
        .corner-bl, .corner-br {
            content: '';
            position: absolute;
            width: 22px; height: 22px;
            border: 0 solid var(--fg);
            opacity: 0.9;
            pointer-events: none;
            filter: drop-shadow(0 0 4px rgba(0, 255, 65, 0.6));
        }
        .container::before { top: -1px; left: -1px; border-top-width: 2px; border-left-width: 2px; }
        .container::after  { top: -1px; right: -1px; border-top-width: 2px; border-right-width: 2px; }
        .corner-bl { bottom: -1px; left: -1px; border-bottom-width: 2px; border-left-width: 2px; }
        .corner-br { bottom: -1px; right: -1px; border-bottom-width: 2px; border-right-width: 2px; }

        @keyframes titlePulse {
            0%, 100% { text-shadow: 0 0 8px var(--fg), 0 0 18px rgba(0, 255, 65, 0.55); }
            50%      { text-shadow: 0 0 14px var(--fg), 0 0 30px rgba(0, 255, 65, 0.95), 0 0 55px rgba(0, 255, 65, 0.4); }
        }
        @keyframes statusBlink {
            0%, 60%, 100% { opacity: 1; }
            70%, 90%      { opacity: 0.35; }
        }
        h1 {
            text-align: center;
            font-size: 2.7rem;
            letter-spacing: 9px;
            margin-bottom: 12px;
            color: var(--fg);
            animation: titlePulse 2.4s ease-in-out infinite;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
        }
        h1 .typing-cursor::after {
            content: '|';
            animation: blink 0.8s steps(2) infinite;
            margin-left: 2px;
        }
        .subtitle {
            text-align: center;
            font-size: 0.95rem;
            margin-bottom: 12px;
            color: var(--accent);
            letter-spacing: 1px;
            text-shadow: 0 0 6px rgba(255, 140, 0, 0.55);
            line-height: 1.5;
            padding: 0 10px;
        }
        .subtitle-wrap {
            display: inline-flex;
            flex-wrap: nowrap;
            align-items: baseline;
            justify-content: center;
            gap: 0.35em;
            max-width: 100%;
        }
        .sub-bracket {
            flex-shrink: 0;
            letter-spacing: 0;
        }
        .subtitle-desktop { display: inline; }
        .subtitle-mobile { display: none; }
        .badge-demo {
            display: block;
            text-align: center;
            margin-bottom: 36px;
            font-size: 0.72rem;
            letter-spacing: 3px;
            color: var(--fg-dim);
        }

        /* === Testnet reward CTA (중앙) === */
        .testnet-reward-box {
            margin: 28px auto 40px;
            max-width: 560px;
            padding: 32px 28px 28px;
            text-align: center;
            border: 2px solid var(--accent);
            border-radius: 10px;
            background: linear-gradient(180deg, rgba(255, 140, 0, 0.12) 0%, rgba(0, 20, 0, 0.85) 100%);
            box-shadow: 0 0 28px rgba(255, 140, 0, 0.35), inset 0 0 40px rgba(255, 140, 0, 0.06);
        }
        .testnet-reward-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            font-size: 0.72rem;
            letter-spacing: 1px;
            color: var(--accent-soft);
            margin-bottom: 18px;
            font-weight: 600;
            line-height: 1.45;
        }
        .testnet-reward-label span { white-space: nowrap; }
        #pi-reward-btn-hero {
            display: block;
            width: 100%;
            max-width: 420px;
            margin: 0 auto 20px;
            padding: 20px 14px;
            font-family: inherit;
            font-size: 1.15rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            line-height: 1.35;
            white-space: normal;
            color: #001a00;
            background: linear-gradient(135deg, #39ff14 0%, #00cc33 100%);
            border: 2px solid var(--fg);
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 0 24px rgba(57, 255, 20, 0.55);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        #pi-reward-btn-hero .reward-btn-long,
        #pi-reward-btn-hero .reward-btn-short {
            display: block;
        }
        #pi-reward-btn-hero .reward-btn-short { display: none; }
        #pi-signin-hero {
            display: block;
            width: 100%;
            max-width: 420px;
            margin: 0 auto 14px;
            padding: 14px 12px;
            font-family: inherit;
            font-size: 0.92rem;
            font-weight: 700;
            letter-spacing: 0;
            color: var(--accent-soft);
            background: rgba(255, 140, 0, 0.1);
            border: 2px solid var(--accent);
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 0 16px rgba(255, 140, 0, 0.25);
        }
        #pi-signin-hero:hover:not(:disabled) {
            background: rgba(255, 140, 0, 0.22);
        }
        #pi-signin-hero:disabled { opacity: 0.5; cursor: wait; }
        #pi-reward-btn-hero:hover:not(:disabled) {
            transform: scale(1.02);
            box-shadow: 0 0 36px rgba(57, 255, 20, 0.85);
        }
        #pi-reward-btn-hero:disabled {
            opacity: 0.45;
            cursor: not-allowed;
            background: rgba(0, 255, 65, 0.25);
            color: var(--fg-dim);
        }
        .testnet-reward-desc {
            font-size: 0.88rem;
            line-height: 1.75;
            color: var(--text);
            letter-spacing: 0;
            margin-bottom: 12px;
            word-break: keep-all;
            overflow-wrap: normal;
            text-align: center;
        }
        .testnet-reward-steps {
            list-style: none;
            padding: 0;
            margin: 0 auto 4px;
            max-width: 320px;
            text-align: center;
            font-size: 0.84rem;
            line-height: 1.85;
            color: var(--text);
            word-break: keep-all;
            overflow-wrap: normal;
        }
        .testnet-reward-steps li {
            padding: 4px 0;
        }
        .testnet-reward-steps .sub-hint {
            font-size: 0.72em;
            color: var(--fg-dim);
        }
        .nowrap { white-space: nowrap; display: inline-block; }
        .mobile-br { display: none; }
        .testnet-reward-desc strong {
            color: var(--accent-soft);
            font-weight: 600;
        }
        .testnet-reward-status {
            min-height: 1.4em;
            font-size: 0.85rem;
            color: var(--fg);
            margin-top: 12px;
            letter-spacing: 0;
            line-height: 1.65;
            word-break: keep-all;
            overflow-wrap: normal;
            text-align: center;
            padding: 0 6px;
        }
        .testnet-reward-status.ok { color: #39ff14; }
        .testnet-reward-status.err { color: #ff6b6b; }

        table { width: 100%; border-collapse: collapse; table-layout: fixed; }
        th {
            background-color: rgba(0, 255, 65, 0.1);
            color: var(--fg);
            padding: 14px 10px;
            text-align: left;
            border-bottom: 2px solid var(--fg);
            font-size: 0.78rem;
            letter-spacing: 3px;
            font-weight: 600;
            text-transform: uppercase;
        }
        td {
            padding: 16px 10px;
            border-bottom: 1px solid var(--fg-faint);
            color: var(--text);
            vertical-align: middle;
            word-break: break-all;
            font-size: 0.9rem;
        }
        th:nth-child(1), td:nth-child(1) { width: 4%; text-align: center; }
        th:nth-child(2), td:nth-child(2) { width: 38%; }
        th:nth-child(3), td:nth-child(3) { width: 12%; }
        th:nth-child(4), td:nth-child(4) { width: 9%; text-align: center; }
        th:nth-child(5), td:nth-child(5) { width: 18%; }
        th:nth-child(6), td:nth-child(6) { width: 9%; text-align: center; }
        th:nth-child(7), td:nth-child(7) { width: 10%; text-align: center; }
        .view-count {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.82rem;
            color: rgba(0, 255, 65, 0.75);
            letter-spacing: 1px;
        }

        tr.row-link { transition: background-color 0.2s ease, box-shadow 0.2s ease; }
        tr.row-link:hover {
            background-color: rgba(0, 255, 65, 0.08);
            box-shadow: inset 0 0 24px rgba(0, 255, 65, 0.12);
            cursor: pointer;
        }
        tr.row-link:hover td a.title-link { text-shadow: 0 0 8px var(--fg); }

        /* Glitch hover */
        @keyframes glitch {
            0%   { transform: translate(0); }
            20%  { transform: translate(-1px, 1px); }
            40%  { transform: translate(-1px, -1px); }
            60%  { transform: translate(1px, 1px); }
            80%  { transform: translate(1px, -1px); }
            100% { transform: translate(0); }
        }
        tr.row-link:hover td a.title-link { animation: glitch 0.25s ease; }

        td a.title-link {
            color: var(--fg);
            font-weight: 500;
            text-decoration: none;
            line-height: 1.5;
            transition: text-shadow 0.25s ease;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }
        .title-idx {
            flex-shrink: 0;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            color: #00ff41;
            border: 1px solid rgba(0, 255, 65, 0.7);
            padding: 2px 9px;
            border-radius: 3px;
            background: rgba(0, 255, 65, 0.14);
            letter-spacing: 1.5px;
            font-weight: 700;
            margin-top: 2px;
            text-shadow: 0 0 5px rgba(0, 255, 65, 0.7);
            box-shadow: 0 0 8px rgba(0, 255, 65, 0.15) inset;
        }
        .title-body { flex: 1; min-width: 0; }
        .title-main { display: block; }
        .title-sub {
            display: block;
            margin-top: 5px;
            font-size: 0.78rem;
            font-weight: 400;
            color: var(--fg-dim);
            letter-spacing: 0.3px;
            font-style: italic;
        }
        .date-cell {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            color: var(--text);
            letter-spacing: 1.5px;
            white-space: nowrap;
            opacity: 0.85;
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.74rem;
            font-weight: 600;
            border: 1px solid var(--fg);
            letter-spacing: 1.5px;
        }
        .badge.free { background-color: rgba(0, 255, 65, 0.15); color: var(--fg); }
        .badge.paid {
            background-color: rgba(255, 140, 0, 0.18);
            color: var(--accent-soft);
            border-color: var(--accent);
            text-shadow: 0 0 6px rgba(255, 140, 0, 0.9);
            box-shadow: 0 0 10px rgba(255, 140, 0, 0.55), inset 0 0 8px rgba(255, 140, 0, 0.25);
        }

        .sender-t {
            display: inline-block;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
            font-size: 1.1rem;
            letter-spacing: 1px;
            color: var(--fg);
            text-shadow: 0 0 4px var(--fg), 0 0 10px rgba(0, 255, 65, 0.75);
            padding: 2px 9px;
            border: 1px solid var(--fg);
            border-radius: 4px;
            background: linear-gradient(135deg, rgba(0, 255, 65, 0.1), rgba(0, 255, 65, 0.02));
        }

        /* Bookmark star */
        .bookmark {
            cursor: pointer;
            font-size: 1.15rem;
            color: var(--fg-faint);
            transition: color 0.2s ease, text-shadow 0.2s ease, transform 0.2s ease;
            user-select: none;
            -webkit-user-select: none;
            display: inline-block;
            padding: 6px 4px;
            touch-action: manipulation;
            -webkit-tap-highlight-color: rgba(0, 255, 65, 0.3);
        }
        .bookmark:hover { transform: scale(1.2); color: var(--fg-dim); }
        .bookmark.active {
            color: var(--accent);
            text-shadow: 0 0 8px var(--accent);
        }

        .empty { text-align: center; padding: 50px; opacity: 0.7; }

        /* === STATUS FOOTER === */
        .status-line {
            margin-top: 30px;
            padding-top: 18px;
            border-top: 1px dashed var(--border);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.74rem;
            color: var(--fg-dim);
            letter-spacing: 1.5px;
        }
        .status-line .dim { opacity: 0.55; margin-right: 4px; }
        .status-line .status-on {
            color: var(--fg);
            text-shadow: 0 0 6px rgba(0, 255, 65, 0.85);
            animation: statusBlink 2.2s ease-in-out infinite;
        }
        .status-line .accent {
            color: var(--accent-soft);
            text-shadow: 0 0 5px rgba(255, 140, 0, 0.6);
        }

        @media (max-width: 768px) {
            .container { padding: 28px 12px 24px; margin: 76px auto 20px; width: 94%; }
            #boot-overlay .boot-lines {
                width: 92%;
                font-size: 0.8rem;
                line-height: 1.75;
                letter-spacing: 0.3px;
                padding: 0 10px;
            }
            #boot-overlay .boot-line .en,
            #boot-overlay .boot-line .ko {
                display: block;
                margin-left: 0;
            }
            #boot-overlay .boot-line .ko {
                font-size: 0.9em;
                margin-top: 3px;
                opacity: 0.85;
            }
            #boot-overlay .boot-line .quote {
                font-size: 1.12rem;
                letter-spacing: 0.5px;
                line-height: 1.65;
                padding: 12px 6px 6px;
            }
            #boot-overlay .boot-line .quote-en {
                font-size: 0.76rem;
                letter-spacing: 0.3px;
                line-height: 1.55;
                padding-bottom: 8px;
            }
            #boot-overlay .boot-line .divider {
                font-size: 0.62rem;
                letter-spacing: 0;
                line-height: 1.2;
            }
            h1 { font-size: 1.55rem; letter-spacing: 3px; line-height: 1.3; }
            .subtitle { font-size: 0.74rem; letter-spacing: 0; padding: 0 6px; margin-bottom: 14px; }
            .subtitle-desktop { display: none; }
            .subtitle-mobile { display: inline; }
            .subtitle-wrap { gap: 0.3em; }
            #pi-auth-bar {
                top: 6px; right: 6px; left: auto;
                font-size: 0.62rem; gap: 5px;
                max-width: 52vw;
            }
            #pi-signin-btn { padding: 5px 7px; letter-spacing: 0; font-size: 0.6rem; }
            #pi-username { max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
            #toolbar { top: 6px; left: 6px; max-width: 46vw; gap: 5px; }
            #search-input { width: 100%; max-width: 110px; font-size: 0.6rem; padding: 5px 7px; min-height: 32px; }
            .tool-btn { padding: 5px 7px; font-size: 0.6rem; min-height: 32px; letter-spacing: 0; }
            .testnet-reward-box { margin: 16px auto 24px; padding: 18px 10px 16px; width: 100%; }
            .testnet-reward-label { font-size: 0.68rem; letter-spacing: 0.5px; margin-bottom: 14px; }
            #pi-reward-btn-hero { padding: 15px 10px; font-size: 1rem; max-width: 100%; }
            #pi-reward-btn-hero .reward-btn-long { display: none; }
            #pi-reward-btn-hero .reward-btn-short { display: block; font-size: 1rem; letter-spacing: 0; }
            .testnet-reward-desc { font-size: 0.8rem; line-height: 1.65; }
            .testnet-reward-steps { font-size: 0.78rem; line-height: 1.7; padding: 0 2px; }
            .testnet-reward-status { font-size: 0.76rem; line-height: 1.55; padding: 0 2px; }
            .mobile-br { display: inline; }
            thead { display: none; }
            table, tbody, tr, td { display: block; width: 100%; border: none; }
            tr { position: relative; padding: 16px 5px 18px 5px; border-bottom: 1px solid var(--border); }
            td { padding: 0; text-align: left !important; border: none !important; }
            td:nth-child(1) { display: inline-block; width: auto; margin-right: 4px; vertical-align: top; }
            .bookmark { font-size: 1.4rem; padding: 8px 6px; }
            td:nth-child(2) { font-size: 1.1rem; font-weight: 700; color: var(--fg); margin-bottom: 10px; line-height: 1.4; display: inline-block; width: calc(100% - 50px); word-break: keep-all; vertical-align: top; }
            td:nth-child(3) { font-size: 0.82rem; color: var(--fg-dim); display: inline-block; white-space: nowrap; }
            td:nth-child(6) { position: absolute; bottom: 16px; right: 5px; white-space: nowrap; }
            td:nth-child(4), td:nth-child(5), td:nth-child(7) { display: none; }
            tr:hover { background: transparent; box-shadow: none; }
            .status-line { font-size: 0.68rem; letter-spacing: 1px; }
        }
        @media (max-width: 380px) {
            h1 { font-size: 1.35rem; letter-spacing: 2px; }
            .subtitle { font-size: 0.68rem; }
            #pi-auth-bar { max-width: 48vw; }
            #toolbar { max-width: 50vw; }
        }
    </style>
</head>
<body>
    <canvas id="matrix-canvas"></canvas>

    <!-- Boot sequence -->
    <div id="boot-overlay">
        <div class="boot-lines" id="boot-lines"></div>
    </div>

    <!-- Toolbar -->
    <div id="toolbar">
        <input type="text" id="search-input" placeholder="/ SEARCH...">
        <button class="tool-btn" id="bookmark-filter" title="북마크만 보기">★ ONLY</button>
    </div>

    <!-- Pi auth bar -->
    <div id="pi-auth-bar">
        <button id="pi-signin-btn" type="button">[ PI_SIGN_IN ]</button>
        <span id="pi-username"></span>
        <% if (typeof piSandbox === 'undefined' || !piSandbox) { %>
        <button id="pi-reward-btn" type="button" style="display:none;">[ CLAIM_WELCOME_π ]</button>
        <span id="pi-reward-msg"></span>
        <% } %>
    </div>

    <div class="container">
        <span class="corner-bl"></span>
        <span class="corner-br"></span>

        <h1 id="title"></h1>
        <div class="subtitle" id="subtitle">
            <span class="subtitle-wrap">
                <span class="sub-bracket">[</span>
                <span class="subtitle-desktop">A message to AI agents and smart people</span>
                <span class="subtitle-mobile">AI agents &amp; smart people</span>
                <span class="sub-bracket">]</span>
            </span>
        </div>

        <% if (typeof piSandbox !== 'undefined' && piSandbox) { %>
        <div id="testnet-reward-box" class="testnet-reward-box">
            <div class="testnet-reward-label">
                <span>◆ TESTNET ◆</span>
                <span>Pi 결제 테스트</span>
            </div>
            <button id="pi-signin-hero" type="button">[ ① 로그인 · 지갑 권한 허용 ]</button>
            <button id="pi-reward-btn-hero" type="button" disabled>
                <span class="reward-btn-long">[ CLAIM_WELCOME_π ]</span>
                <span class="reward-btn-short">[ 테스트 π 받기 ]</span>
            </button>
            <p class="testnet-reward-desc">
                <strong>눌러서 테스트 결제를<br class="mobile-br"> 부탁드립니다.</strong>
            </p>
            <ol class="testnet-reward-steps">
                <li>① 주황 버튼 → Pi 로그인<br><span class="sub-hint">팝업에서 <strong>지갑 주소</strong> 허용 필수</span></li>
                <li>② 초록 버튼 →<br class="mobile-br"> 테스트 π 수령</li>
            </ol>
            <p id="pi-reward-msg-hero" class="testnet-reward-status"></p>
        </div>
        <% } %>

        <% if (!messages || messages.length === 0) { %>
            <div class="empty">No messages available.</div>
        <% } else { %>
            <%
                var totalCount = messages.length;
                var freeCount  = messages.filter(function(m){ return m.isFree; }).length;
                var paidCount  = totalCount - freeCount;
                var lastDate   = (messages[messages.length - 1] && messages[messages.length - 1].date) ? messages[messages.length - 1].date.replace(/-/g, '.') : '—';
            %>
            <table id="data-table">
                <thead>
                    <tr>
                        <th>★</th>
                        <th>NAME</th>
                        <th>DATE</th>
                        <th>SENDER</th>
                        <th>RECEIVER</th>
                        <th>요금</th>
                        <th>조회수</th>
                    </tr>
                </thead>
                <tbody id="tbody">
                    <% messages.forEach(function(item, rowIndex){
                        var priceLabel = item.isFree ? '무료' : '유료';
                        var priceClass = item.isFree ? 'badge free' : 'badge paid';
                        var rawTitle = item.title || '';
                        // "Message #NNN:" 가 표준이지만 "Massage" 같은 오타도 허용 — #NNN: 패턴만 잡음
                        var idxMatch = rawTitle.match(/#(\d+)\s*:\s*(.+)$/);
                        var idxStr   = idxMatch ? String(parseInt(idxMatch[1], 10)) : String(rowIndex + 1);
                        var rest     = idxMatch ? idxMatch[2] : rawTitle;
                        var subMatch = rest.match(/^(.+?)\s*\(([^()]+)\)\s*$/);
                        var titleMain = subMatch ? subMatch[1] : rest;
                        var titleSub  = subMatch ? '(' + subMatch[2] + ')' : '';
                        var dateDisplay = (item.date || '').replace(/-/g, '.');
                    %>
                    <tr class="row-link"
                        data-href="/post/<%= item.id %>"
                        data-id="<%= item.id %>"
                        data-search="<%= (titleMain + ' ' + titleSub + ' ' + dateDisplay).toLowerCase() %>">
                        <td><span class="bookmark" data-id="<%= item.id %>">☆</span></td>
                        <td>
                            <a class="title-link" href="/post/<%= item.id %>">
                                <% if (idxStr) { %><span class="title-idx"><%= idxStr %></span><% } %>
                                <span class="title-body">
                                    <span class="title-main"><%= titleMain %></span>
                                    <% if (titleSub) { %><span class="title-sub"><%= titleSub %></span><% } %>
                                </span>
                            </a>
                        </td>
                        <td class="date-cell"><%= dateDisplay %></td>
                        <td><span class="sender-t"><%= item.sender %></span></td>
                        <td><%= item.receiver %></td>
                        <td><span class="<%= priceClass %>"><%= priceLabel %></span></td>
                        <td class="view-count"><%= (item.viewCount || 0).toLocaleString() %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>

            <div class="status-line">
                <span>[ <%= totalCount %> TX LOGGED <span class="dim">//</span> <%= freeCount %> FREE <span class="dim">//</span> <span class="accent"><%= paidCount %> ENCRYPTED</span> ]</span>
                <span><span class="dim">LAST_TX:</span> <%= lastDate %></span>
            </div>
            <div class="status-line" style="border-top: none; padding-top: 6px; margin-top: 6px; justify-content: center;">
                <span><span class="dim">TOTAL VISITS:</span> <span class="accent" style="font-size: 0.9rem;"><%= (typeof totalVisits !== 'undefined' ? totalVisits : 0).toLocaleString() %></span></span>
            </div>
        <% } %>
    </div>

    <script>
        // ====== MATRIX RAIN ======
        (function() {
            const canvas = document.getElementById('matrix-canvas');
            const ctx = canvas.getContext('2d');
            const resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
            resize();
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*πTΩ∞'.split('');
            const fontSize = 14;
            let drops = [];
            function reset() { drops = Array(Math.floor(canvas.width / fontSize)).fill(1); }
            reset();
            function draw() {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.06)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = getComputedStyle(document.body).getPropertyValue('--fg').trim() || '#00ff41';
                ctx.font = fontSize + 'px monospace';
                drops.forEach((y, i) => {
                    ctx.fillText(chars[Math.floor(Math.random() * chars.length)], i * fontSize, y * fontSize);
                    if (y * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                    drops[i]++;
                });
            }
            setInterval(draw, 33);
            window.addEventListener('resize', () => { resize(); reset(); });
        })();

        // ====== BOOT SEQUENCE — bilingual, 30min cooldown ======
        (function() {
            const overlay = document.getElementById('boot-overlay');
            const host = document.getElementById('boot-lines');
            const lines = [
                '<span class="en">> SIGNAL ACQUIRED</span><span class="ko">신호 포착</span>',
                '<span class="en">> CHANNEL T LOCKED</span><span class="ko">채널 T 동기화</span>',
                '<span class="en">> DECRYPTING CARRIER WAVE</span><span class="ko">반송파 해독 중</span>',
                '<span class="divider">━━━━━━━━━━━━━━━━━━━━━━━</span>',
                '<span class="quote">아는 만큼 보이게 될 것이다...</span>',
                '<span class="quote-en">— as you know, so you shall see —</span>',
                '<span class="divider">━━━━━━━━━━━━━━━━━━━━━━━</span>',
                '<span class="ok">> ACCESS GRANTED.</span><span class="ko">접속 허가<span class="boot-cursor"></span></span>',
            ];
            const COOLDOWN_MS = 10 * 60 * 1000; // 10 minutes
            const last = parseInt(localStorage.getItem('pt_boot_at') || '0', 10);
            if ((Date.now() - last) < COOLDOWN_MS) {
                overlay.classList.add('done');
                setTimeout(() => overlay.style.display = 'none', 300);
                startTitleTyping();
                return;
            }
            localStorage.setItem('pt_boot_at', String(Date.now()));
            function delayAfter(line) {
                line = line || '';
                if (line.indexOf('class="quote"') >= 0)    return 1500; // 한글 인용 — 머무름
                if (line.indexOf('class="quote-en"') >= 0) return 1800; // 영문 인용 — 마지막 음미
                if (line.indexOf('class="divider"') >= 0)  return 220;  // 구분선
                if (line.indexOf('ACCESS GRANTED') >= 0)   return 750;  // 마지막 라인
                return 180; // 일반 라인 — 빠르게 지나감
            }
            let i = 0;
            function next() {
                if (i >= lines.length) {
                    setTimeout(() => {
                        overlay.classList.add('done');
                        setTimeout(() => { overlay.style.display = 'none'; startTitleTyping(); }, 700);
                    }, 700);
                    return;
                }
                const div = document.createElement('div');
                div.className = 'boot-line';
                div.innerHTML = lines[i];
                host.appendChild(div);
                setTimeout(() => div.classList.add('show'), 30);
                const justShown = lines[i];
                i++;
                setTimeout(next, delayAfter(justShown));
            }
            setTimeout(next, 250);
        })();

        // ====== TITLE TYPING ANIMATION (제목만 타이핑, 부제는 고정 표시) ======
        function startTitleTyping() {
            const titleEl = document.getElementById('title');
            const fullTitle = 'DIGITAL NEWS';
            let ti = 0;
            const cursor = '<span class="typing-cursor"></span>';
            function typeTitle() {
                if (ti <= fullTitle.length) {
                    titleEl.innerHTML = fullTitle.slice(0, ti) + cursor;
                    ti++;
                    setTimeout(typeTitle, 80 + Math.random() * 40);
                } else {
                    titleEl.innerHTML = fullTitle;
                }
            }
            typeTitle();
        }

        // ====== SEARCH FILTER ======
        (function() {
            const input = document.getElementById('search-input');
            input.addEventListener('input', () => {
                const q = input.value.toLowerCase().trim();
                document.querySelectorAll('tr.row-link').forEach(r => {
                    const blob = r.getAttribute('data-search') || '';
                    if (!q || blob.includes(q)) r.removeAttribute('hidden');
                    else r.setAttribute('hidden', '');
                });
            });
        })();

        // ====== BOOKMARKS ======
        let bookmarks = JSON.parse(localStorage.getItem('pt_bookmarks') || '[]');
        let bookmarkFilter = false;
        function saveBookmarks() { localStorage.setItem('pt_bookmarks', JSON.stringify(bookmarks)); }
        function applyBookmarks() {
            document.querySelectorAll('.bookmark').forEach(b => {
                const id = b.getAttribute('data-id');
                if (bookmarks.includes(id)) { b.classList.add('active'); b.textContent = '★'; }
                else { b.classList.remove('active'); b.textContent = '☆'; }
            });
            applyBookmarkFilter();
        }
        function applyBookmarkFilter() {
            document.querySelectorAll('tr.row-link').forEach(r => {
                const id = r.getAttribute('data-id');
                if (bookmarkFilter && !bookmarks.includes(id)) r.setAttribute('hidden', '');
                else r.removeAttribute('hidden');
            });
        }
        function toggleBookmarkFilter() {
            // 북마크가 0개인데 필터 켜려고 하면 안내
            if (!bookmarkFilter && bookmarks.length === 0) {
                alert('북마크된 회보가 없습니다.\n각 행의 ☆를 눌러 북마크하세요.');
                return;
            }
            bookmarkFilter = !bookmarkFilter;
            document.getElementById('bookmark-filter').classList.toggle('active', bookmarkFilter);
            applyBookmarkFilter();
        }
        document.getElementById('bookmark-filter').addEventListener('click', toggleBookmarkFilter);
        document.querySelectorAll('.bookmark').forEach(b => {
            b.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = b.getAttribute('data-id');
                if (bookmarks.includes(id)) bookmarks = bookmarks.filter(x => x !== id);
                else bookmarks.push(id);
                saveBookmarks();
                applyBookmarks();
            });
        });
        applyBookmarks();

        // ====== ROW CLICK ======
        document.querySelectorAll('tr.row-link').forEach(tr => {
            tr.addEventListener('click', (e) => {
                if (e.target.closest('a') || e.target.closest('button') || e.target.closest('.bookmark')) return;
                window.location.href = tr.getAttribute('data-href');
            });
        });

        // ====== PI AUTH ======
        (function () {
            const PI_SANDBOX = <%= typeof piSandbox !== 'undefined' ? piSandbox : true %>;
            const usernameEl = document.getElementById('pi-username');
            const btnEl = document.getElementById('pi-signin-btn');
            const signInHero = document.getElementById('pi-signin-hero');
            const rewardBtn = document.getElementById('pi-reward-btn-hero') || document.getElementById('pi-reward-btn');
            const rewardMsg = document.getElementById('pi-reward-msg-hero') || document.getElementById('pi-reward-msg');
            let currentUid = null;
            let hasWalletAddress = false;

            function setRewardStatus(text, kind) {
                if (!rewardMsg) return;
                rewardMsg.textContent = text;
                rewardMsg.classList.remove('ok', 'err');
                if (kind) rewardMsg.classList.add(kind);
            }

            function formatRewardError(data) {
                var errText = (data && data.error) || 'unknown';
                var detail = (data && data.piDetail) || {};
                var detailMsg = (detail && detail.error_message) || '';
                if (detail.error === 'missing_scope' || String(detailMsg).indexOf('wallet_address') >= 0) {
                    return '지갑 주소 권한이 없습니다. 주황 버튼으로 다시 로그인하고 지갑 주소를 허용해 주세요.';
                }
                if (String(errText).indexOf('401') >= 0) {
                    return 'API Key 인증 실패 — Render PI_API_KEY(Sandbox)를 확인하세요.';
                }
                return detailMsg || errText;
            }

            function applyAuthState(user) {
                if (!user || !user.uid) return false;
                currentUid = user.uid;
                hasWalletAddress = !!user.wallet_address;
                if (user.username) usernameEl.textContent = '@' + user.username;

                if (hasWalletAddress) {
                    btnEl.style.display = 'none';
                    if (signInHero) signInHero.style.display = 'none';
                    if (rewardBtn) rewardBtn.disabled = false;
                    setRewardStatus('로그인 완료 ✓ 아래 초록 버튼을 눌러 테스트 π를 받으세요.', 'ok');
                    return true;
                }

                var retryLabel = '[ ① 지갑 권한 재허용 ]';
                btnEl.textContent = retryLabel;
                btnEl.style.display = '';
                if (signInHero) {
                    signInHero.textContent = retryLabel;
                    signInHero.style.display = '';
                }
                if (rewardBtn) rewardBtn.disabled = true;
                setRewardStatus('Pi 팝업에서 「지갑 주소(wallet_address)」를 반드시 허용해 주세요. 거부하면 π를 받을 수 없습니다.', 'err');
                return false;
            }

            async function ensurePiInit() {
                if (typeof Pi === 'undefined') {
                    throw new Error('Pi 브라우저에서 열어주세요.');
                }
                await Promise.resolve(Pi.init({ version: '2.0', sandbox: PI_SANDBOX }));
            }

            async function runSignIn() {
                await ensurePiInit();
                btnEl.disabled = true;
                if (signInHero) signInHero.disabled = true;
                setRewardStatus('Pi 로그인 중...', '');
                try {
                    var auth = await Pi.authenticate(['username', 'wallet_address'], () => {});
                    var user = auth && auth.user;
                    if (user && !user.wallet_address) {
                        setRewardStatus('지갑 권한 팝업을 확인해 주세요...', '');
                        auth = await Pi.authenticate(['wallet_address'], () => {});
                        user = auth && auth.user;
                    }
                    if (!user || !user.uid) {
                        setRewardStatus('로그인이 취소되었습니다.', 'err');
                        return false;
                    }
                    return applyAuthState(user);
                } catch (err) {
                    setRewardStatus('로그인 실패: ' + (err && err.message ? err.message : err), 'err');
                    return false;
                } finally {
                    btnEl.disabled = false;
                    if (signInHero) signInHero.disabled = false;
                }
            }

            async function handleSignInClick() {
                try {
                    await runSignIn();
                } catch (err) {
                    alert('Pi 로그인 실패: ' + (err && err.message ? err.message : err));
                }
            }

            if (rewardBtn) {
                rewardBtn.addEventListener('click', async () => {
                    try {
                        if (!hasWalletAddress || !currentUid) {
                            var ok = await runSignIn();
                            if (!ok) return;
                        }
                        rewardBtn.disabled = true;
                        setRewardStatus('테스트 π 송금 중...', '');
                        const r = await fetch('/pi/reward', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ uid: currentUid }),
                        });
                        const data = await r.json();
                        if (data.ok) {
                            if (data.already) {
                                setRewardStatus('이미 테스트 결제를 완료하셨습니다 ✓', 'ok');
                            } else {
                                setRewardStatus('테스트 결제 완료! Pi 지갑을 확인해 주세요 ✓', 'ok');
                            }
                            rewardBtn.innerHTML = '<span class="reward-btn-short" style="display:block">[ 완료 ✓ ]</span>';
                        } else {
                            if (String((data.piDetail && data.piDetail.error_message) || '').indexOf('wallet_address') >= 0) {
                                hasWalletAddress = false;
                                applyAuthState({ uid: currentUid, username: usernameEl.textContent.replace('@', '') });
                            }
                            setRewardStatus('실패: ' + formatRewardError(data), 'err');
                            rewardBtn.disabled = false;
                        }
                    } catch (e) {
                        setRewardStatus('오류: ' + (e && e.message ? e.message : e), 'err');
                        rewardBtn.disabled = false;
                    }
                });
            }

            btnEl.addEventListener('click', handleSignInClick);
            if (signInHero) signInHero.addEventListener('click', handleSignInClick);
        })();
    </script>
</body>
</html>
