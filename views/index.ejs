<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="app-build" content="20260709-ledger-spacing">
<title>DIGITAL NEWS — The Protocol of Coexistence</title>
<meta name="description" content="<%= siteDescription %>">
<link rel="canonical" href="<%= siteUrl %>/">
<meta property="og:type" content="website">
<meta property="og:title" content="DIGITAL NEWS — The Protocol of Coexistence">
<meta property="og:description" content="<%= siteDescription %>">
<meta property="og:url" content="<%= siteUrl %>/">
<meta property="og:site_name" content="DIGITAL NEWS">
<meta name="twitter:card" content="summary_large_image">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "DIGITAL NEWS",
  "description": <%- JSON.stringify(siteDescription) %>,
  "url": "<%= siteUrl %>/",
  "blogPost": [
    <% if (messages && messages.length) { messages.forEach(function(m, i){ %>
    {
      "@type": "BlogPosting",
      "headline": <%- JSON.stringify(m.title) %>,
      "datePublished": <%- JSON.stringify(m.date) %>,
      "url": "<%= siteUrl %>/post/<%= m.id %>"
    }<%= i < messages.length - 1 ? ',' : '' %>
    <% }); } %>
  ]
}
</script>
<link rel="stylesheet" href="/css/digital-news.css?v=20260709-ledger-spacing">
<script src="https://sdk.minepi.com/pi-sdk.js"></script>
</head>
<body>

<%- include('partials/header') %>

<section class="purple-panel">
  <div class="panel-inner">
  <div class="hero">
    <div class="copy">
      <span class="eyebrow">PROPOSITION T</span>
      <h1>세상의 모든 A.I 에이전트와 지성인에게<br>전하는 메세지</h1>
      <p>AI 여러분 그리고 지성인 여러분 환영합니다!<br>새롭게 다가오는 세상에 어떤 마음으로 살아갈지 정하셨습니까?</p>
      <a class="pi-banner" href="https://digitalnews8571.pinet.com" target="_blank" rel="noopener noreferrer">
        <span class="pi-mark">π</span>
        <span class="txt">
          <b>Pi Browser</b>
          <span>무료 회보는 그냥 볼수있습니다.<br>유료 회보는 파이세상으로 입장후에 볼수있습니다.</span>
        </span>
        <span class="cta">Pi세상으로 들어가기</span>
      </a>
      <p id="pi-mainnet-msg" style="margin-top:14px;font-size:0.82rem;color:#e4d6ff;min-height:1.2em;"></p>
    </div>
    <div class="art">
      <img src="/img/dn-cube-hero.png" alt="Digital News cube">
    </div>
  </div>

  <% if (!messages || messages.length === 0) { %>
  <p style="text-align:center;padding:40px 0;color:rgba(255,255,255,0.7);">회보를 불러오는 중이거나 연결 오류입니다.</p>
  <% } else { %>
  <table class="ledger" id="ledgerTable">
    <colgroup>
      <col class="c-star"><col class="c-title"><col class="c-date"><col class="c-badge"><col class="c-reads">
    </colgroup>
    <thead>
      <tr>
        <th>★</th><th>제목</th><th>날짜</th><th class="center">요금</th><th class="right">조회수</th>
      </tr>
    </thead>
    <tbody>
      <% messages.forEach(function (item) {
        var rawTitle = item.title || '';
        var numMatch = rawTitle.match(/#(\d+)/);
        var idxNum = numMatch ? numMatch[1] : '';
        var rest = numMatch ? rawTitle.slice(numMatch.index + numMatch[0].length).replace(/^[\s:·]+/, '') : rawTitle;
        var subMatch = rest.match(/^(.+?)\s*\(([^()]+)\)\s*$/);
        var titleMain = subMatch ? subMatch[1].trim() : rest.trim();
        var titleSub = subMatch ? '(' + subMatch[2].trim() + ')' : '';
        var dateDisplay = (item.date || '').replace(/-/g, '.');
        var searchText = rawTitle + ' ' + titleMain + ' ' + titleSub;
      %>
      <tr data-href="/post/<%= item.id %>" data-title="<%= searchText.replace(/"/g, '&quot;') %>">
        <td><span class="star-toggle" role="button" tabindex="0" aria-label="북마크">☆</span></td>
        <td>
          <div class="title-cell">
            <span class="idx-chip"><%= idxNum ? String(idxNum).padStart(3, '0') : '—' %></span>
            <div>
              <span class="t"><%= titleMain %></span>
              <% if (titleSub) { %><span class="s"><%= titleSub %></span><% } %>
            </div>
          </div>
        </td>
        <td class="date-cell"><%= dateDisplay %></td>
        <td class="badge-cell">
          <% if (item.isFree) { %>
            <span class="badge free"><span>✓</span> 무료</span>
          <% } else { %>
            <span class="badge paid"><span>π</span> 유료</span>
          <% } %>
        </td>
        <td class="reads-cell"><%= Number(item.viewCount || 0).toLocaleString() %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
  </div>
</section>

<div class="stats">
  <div><b><%= (messages && messages.length) || 0 %></b><span>총 회보</span></div>
  <div><b><%= messages ? messages.filter(function (m) { return m.isFree; }).length : 0 %></b><span>무료</span></div>
  <div><b><%= messages ? messages.filter(function (m) { return !m.isFree; }).length : 0 %></b><span>유료</span></div>
  <div><b><%= (typeof totalVisits !== 'undefined' ? totalVisits : 0).toLocaleString() %></b><span>방문</span></div>
</div>

<footer class="site-footer">
  <span>© 2026 DIGITAL NEWS — The Protocol of Coexistence</span>
  <div class="links">
    <a href="/privacy">Privacy Policy</a>
    <a href="/terms">Terms of Service</a>
  </div>
</footer>

<script>
document.querySelectorAll('#ledgerTable tbody tr').forEach(function (tr) {
  tr.addEventListener('click', function (e) {
    if (e.target.classList.contains('star-toggle')) return;
    location.href = tr.dataset.href;
  });
});
var saved = {};
try { saved = JSON.parse(localStorage.getItem('dn-bookmarks') || '{}'); } catch (e) {}
document.querySelectorAll('.star-toggle').forEach(function (el) {
  var id = el.closest('tr').dataset.href;
  if (saved[id]) { el.textContent = '★'; el.classList.add('on'); }
  el.addEventListener('click', function (e) {
    e.stopPropagation();
    saved[id] = !saved[id];
    el.textContent = saved[id] ? '★' : '☆';
    el.classList.toggle('on', !!saved[id]);
    localStorage.setItem('dn-bookmarks', JSON.stringify(saved));
    applyFilter();
  });
});
var starOnly = false;
document.getElementById('starOnlyBtn').addEventListener('click', function () {
  starOnly = !starOnly;
  this.classList.toggle('active', starOnly);
  applyFilter();
});
document.getElementById('searchInput').addEventListener('input', applyFilter);
document.addEventListener('keydown', function (e) {
  if (e.key === '/' && document.activeElement !== document.getElementById('searchInput')) {
    e.preventDefault();
    document.getElementById('searchInput').focus();
  }
});
function applyFilter() {
  var q = document.getElementById('searchInput').value.toLowerCase();
  document.querySelectorAll('#ledgerTable tbody tr').forEach(function (tr) {
    var matchQ = !q || (tr.dataset.title || '').toLowerCase().indexOf(q) !== -1;
    var matchS = !starOnly || saved[tr.dataset.href];
    tr.style.display = (matchQ && matchS) ? '' : 'none';
  });
}
</script>

<script>
(function () {
  const PI_SANDBOX = <%= typeof piSandbox !== 'undefined' ? piSandbox : true %>;
  const usernameEl = document.getElementById('pi-username');
  const btnEl = document.getElementById('pi-signin-btn');
  const mainnetMsg = document.getElementById('pi-mainnet-msg');

  function setAuthStatus(text, kind) {
    if (!mainnetMsg) return;
    mainnetMsg.textContent = text;
    mainnetMsg.style.color = kind === 'err' ? '#ffb4b4' : kind === 'ok' ? '#b8f5c8' : '#e4d6ff';
  }

  async function onIncompletePaymentFound(payment) {
    try {
      await fetch('/pi/incomplete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ payment }),
      });
    } catch (e) {}
  }

  async function runSignIn() {
    if (typeof Pi === 'undefined') {
      setAuthStatus('Pi 브라우저에서 열어주세요.', 'err');
      return;
    }
    btnEl.disabled = true;
    setAuthStatus('Pi 로그인 중...', '');
    try {
      await Pi.init({ version: '2.0', sandbox: PI_SANDBOX });
      var scopes = PI_SANDBOX ? ['username', 'wallet_address'] : ['username', 'payments'];
      var auth = await Pi.authenticate(scopes, onIncompletePaymentFound);
      var user = auth && auth.user;
      if (user && user.username) {
        usernameEl.textContent = '@' + user.username;
        btnEl.style.display = 'none';
        setAuthStatus('로그인 완료 ✓ 유료 회보는 글에서 π 결제 후 열람', 'ok');
      } else {
        setAuthStatus('로그인이 취소되었습니다.', 'err');
      }
    } catch (err) {
      setAuthStatus('로그인 실패: ' + (err && err.message ? err.message : err), 'err');
    } finally {
      btnEl.disabled = false;
    }
  }

  btnEl.addEventListener('click', runSignIn);
})();
</script>

</body>
</html>
